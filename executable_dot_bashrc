chezpush() {
    chezmoi re-add
    cd ~/.local/share/chezmoi
    git add .
    git commit -m "${1:-dotfiles update}"
    git push
    cd ~
}

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
PS1='[\u@\h \W]\$ '
export PATH="$HOME/.local/bin:$PATH"
